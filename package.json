{
  "name": "jash_muun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "yarn i18n:compile",
    "build": "vite build",
    "preview": "vite preview",
    "datocms:schema": "node ./scripts/fetch-datocms-schema.mjs",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --strategy baseLocale",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.15.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "postcss": "^8.4.49",
    "svelte": "^5.17.3",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.7",
    "@inlang/paraglide-js": "^2.16.0"
  }
}
